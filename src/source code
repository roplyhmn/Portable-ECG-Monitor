#include "main.h"
#include "ssd1306.h"
#include "ssd1306_fonts.h"
#include <stdio.h>

ADC_HandleTypeDef hadc1;
I2C_HandleTypeDef hi2c1;

uint32_t adc_value;
int x_pos = 0;
int y_old = 0;
uint32_t last_beat_time = 0;
uint32_t current_time = 0;
float bpm = 0;
int threshold = 3000;
int is_beat = 0;

void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_ADC1_Init(void);
static void MX_I2C1_Init(void);

int main(void)
{
    HAL_Init();

    SystemClock_Config();

    MX_GPIO_Init();
    MX_ADC1_Init();
    MX_I2C1_Init();

    ssd1306_Init();

    while (1)
    {
        HAL_ADC_Start(&hadc1);

        if (HAL_ADC_PollForConversion(&hadc1, 10) == HAL_OK)
        {
            adc_value = HAL_ADC_GetValue(&hadc1);
        }

        HAL_ADC_Stop(&hadc1);

        current_time = HAL_GetTick();

        if (adc_value > threshold && is_beat == 0)
        {
            uint32_t duration = current_time - last_beat_time;

            if (duration > 300)
            {
                bpm = 60000.0 / duration;
                last_beat_time = current_time;
                is_beat = 1;
            }
        }

        if (adc_value < (threshold - 200))
        {
            is_beat = 0;
        }

        static uint32_t last_display_time = 0;

        if (current_time - last_display_time > 200)
        {
            char msg[15];

            sprintf(msg, "BPM: %.1f ", bpm);

            ssd1306_Fill(Black);

            ssd1306_SetCursor(10, 10);
            ssd1306_WriteString("HEART RATE", Font_7x10, White);

            ssd1306_SetCursor(10, 30);
            ssd1306_WriteString(msg, Font_11x18, White);

            ssd1306_UpdateScreen();

            last_display_time = current_time;
        }

        HAL_Delay(10);
    }
}
